{
  "name": "@srinivasa314/ovid",
  "version": "0.0.2",
  "description": "A minimal coding-agent layer on pi that records terminal+browser test videos onto PRs",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Srinivasa314/ovid.git"
  },
  "homepage": "https://github.com/Srinivasa314/ovid#readme",
  "bugs": {
    "url": "https://github.com/Srinivasa314/ovid/issues"
  },
  "keywords": [
    "pi",
    "coding-agent",
    "e2e",
    "playwright",
    "terminal",
    "video",
    "pull-request"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "ovid": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./test": "./dist/test.js"
  },
  "files": [
    "dist",
    "assets",
    "scripts"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "demo": "tsx src/cli.ts demo:terminal",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "dependencies": {
    "@playwright/test": "^1.61.1",
    "@xterm/xterm": "^6.0.0",
    "commander": "^15.0.0",
    "ffmpeg-static": "^5.3.0",
    "node-pty": "^1.1.0",
    "playwright": "^1.61.1",
    "playwright-recorder-plus": "^0.1.3"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@types/node": "^24.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
